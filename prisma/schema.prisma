generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("Globe")
  gradient    String   @default("from-blue-500 to-cyan-500")
  benefits    String   @default("[]")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  author    String
  role      String   @default("")
  company   String   @default("")
  rating    Int      @default(5)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  category    String   @default("")
  description String
  icon        String   @default("Users")
  gradient    String   @default("from-blue-600 to-cyan-500")
  tags        String   @default("[]")
  results     String   @default("[]")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Industry {
  id        String   @id @default(cuid())
  title     String
  icon      String   @default("HeartPulse")
  gradient  String   @default("from-rose-500 to-pink-500")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  service   String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
}
